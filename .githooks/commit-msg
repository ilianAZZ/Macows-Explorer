#!/bin/sh
# Mutka commit-msg hook — enforce Conventional Commits locally so release-please
# can compute versions + changelog. Bypass with --no-verify. The authoritative,
# un-bypassable check runs on PRs (.github/workflows/commitlint.yml).
#
# Enabled via the "prepare" script: git config core.hooksPath .githooks

header=$(head -n1 "$1")

# Let git's own housekeeping commits through.
case "$header" in
  "Merge "* | "Revert "* | "fixup!"* | "squash!"* | "release-please"* | "chore(main): release"*)
    exit 0
    ;;
esac

# type(optional scope)(optional !): subject
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9 ._/-]+\))?!?: .+'
if printf '%s' "$header" | grep -Eq "$pattern"; then
  exit 0
fi

echo "" >&2
echo "✗ Not a Conventional Commit:" >&2
echo "    $header" >&2
echo "" >&2
echo "  Format:   type(scope)?: subject     e.g.  feat(modules): add tags panel" >&2
echo "  Types:    feat fix docs style refactor perf test build ci chore revert" >&2
echo "  Release:  fix → patch · feat → minor · feat! (or 'BREAKING CHANGE:' footer) → MAJOR" >&2
echo "  Bypass:   git commit --no-verify" >&2
echo "" >&2
exit 1
